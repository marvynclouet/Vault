# AI Provider : "groq" (gratuit) ou "openai"
AI_PROVIDER=groq

# Groq (gratuit — https://console.groq.com)
GROQ_API_KEY=gsk_...

# OpenAI (payant — optionnel, si AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Modèles (défauts pour Groq, changer si OpenAI)
LLM_MODEL=llama-3.3-70b-versatile
WHISPER_MODEL=whisper-large-v3-turbo

# Trello (optionnel)
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID=

# Webhook (optionnel)
WEBHOOK_URL=

# CORS
ALLOWED_ORIGINS=["*"]
