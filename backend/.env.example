# OpenAI (requis)
OPENAI_API_KEY=sk-...

# Trello (requis pour créer des cartes)
TRELLO_API_KEY=your_trello_api_key
TRELLO_API_TOKEN=your_trello_api_token
TRELLO_BOARD_ID=your_board_id
TRELLO_LIST_ID=your_list_id

# Webhook externe (optionnel - n8n, Make.com, etc.)
WEBHOOK_URL=

# LLM config
LLM_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

# CORS (ouvert pour dev mobile, restreindre en production)
ALLOWED_ORIGINS=["*"]
